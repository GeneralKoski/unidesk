# Copia in `.env`. Il file `.env` è in .gitignore: non viene mai committato.

# --- Sessione (OBBLIGATORIO) ---
# Chiave per cifrare il cookie di sessione. >= 32 caratteri, casuale.
# Genera con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# --- Base URL (opzionali, default Unipr) ---
# Gli utenti si autenticano via login: qui NON servono credenziali.
ESSE3_BASE=https://unipr.esse3.cineca.it/e3rest/api
ELLY_BASE=https://elly2025.didattica.unipr.it
