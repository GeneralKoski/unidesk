# Copia in `.env` e compila con le tue credenziali reali.
# Il file `.env` è in .gitignore: non viene mai committato.

# --- Esse3 (REST e3rest, HTTP Basic Auth) ---
ESSE3_BASE=https://unipr.esse3.cineca.it/e3rest/api
ESSE3_USER=nome.cognome@studenti.unipr.it
ESSE3_PASS=

# --- Elly (Moodle, web service mobile) ---
# Base del Moodle del dipartimento (senza slash finale).
ELLY_BASE=https://elly2025.scienze.unipr.it
ELLY_USER=nome.cognome
ELLY_PASS=
