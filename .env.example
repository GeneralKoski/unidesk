# Copia in `.env` e compila con le tue credenziali reali.
# Il file `.env` è in .gitignore: non viene mai committato.

# --- Esse3 (REST e3rest, HTTP Basic Auth) ---
ESSE3_BASE=https://unipr.esse3.cineca.it/e3rest/api
ESSE3_USER=nome.cognome@studenti.unipr.it
ESSE3_PASS=

# --- Elly (Moodle via Shibboleth SSO) ---
# Base del Moodle (senza slash finale). Login automatico con le credenziali
# Unipr (stesse di Esse3) tramite l'IdP shibidp.unipr.it.
ELLY_BASE=https://elly2025.didattica.unipr.it
ELLY_USER=nome.cognome@studenti.unipr.it
ELLY_PASS=
